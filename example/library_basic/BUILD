load("//groovy:groovy.bzl", "groovy_library")

# Smallest possible example: one Groovy source, no Java, no dependencies
# beyond the toolchain-resolved Groovy runtime.
groovy_library(
    name = "greeter",
    srcs = ["src/main/groovy/greeter/Greeter.groovy"],
    visibility = ["//visibility:public"],
)
